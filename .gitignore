# Local-only reference symlink to the parent project (machine-specific absolute path)
/st-zephyr

# Go gateway build output
gateway/jast-gw
*.db

# Build artifacts / caches
build/
build-host/
__pycache__/
*.pyc

# Smoke-test captured artifacts (regenerated from jag)
host/image
host/*.image
host/image.crc32
host/firmware

# Toit
.packages/

# No-jaguar supervisor envelope build artifacts (regenerated by host/build-envelope.sh)
/firmware-esp32.envelope
/firmware-esp32.envelope.gz
/supervisor.snapshot
/supervisor.image

# Payload image build artifacts (regenerated from device/*.toit sources)
/chatty.snapshot
/chatty.bin
/control_demo.snapshot
/control_demo.bin
